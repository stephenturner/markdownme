{
  "name": "markdownme",
  "displayName": "markdownme",
  "version": "1.1.0",
  "description": "Convert web page to markdown with one click",
  "author": "Stephen Turner",
  "scripts": {
    "dev": "plasmo dev --target=firefox-mv3",
    "build": "plasmo build --target=firefox-mv3 --zip --source-maps"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@types/mozilla-readability": "^0.2.1",
    "markdown-to-jsx": "^9.7.15",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.10",
    "prettier": "3.2.4",
    "tailwindcss": "3",
    "typescript": "5.3.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "esbuild",
      "lmdb",
      "msgpackr-extract",
      "sharp"
    ]
  },
  "manifest": {
    "permissions": [
      "storage"
    ],
    "host_permissions": [
      "https://*/*"
    ],
    "commands": {
      "convert-to-markdown": {
        "suggested_key": {
          "default": "Alt+M"
        },
        "description": "Convert current page to Markdown"
      }
    },
    "browser_specific_settings": {
      "gecko": {
        "id": "markdownme@vustephen",
        "data_collection_permissions": {
          "required": [
            "none"
          ]
        }
      }
    }
  }
}